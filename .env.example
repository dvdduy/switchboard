SWITCHBOARD_ENVIRONMENT=local
SWITCHBOARD_DATABASE_URL=postgresql+psycopg://switchboard:switchboard@localhost:5432/switchboard
SWITCHBOARD_REDIS_URL=redis://localhost:6379/0
SWITCHBOARD_LOG_LEVEL=INFO

# Used by PostgreSQL integration tests. The default test fixture uses
# this same URL when the variable is not explicitly defined.
SWITCHBOARD_TEST_DATABASE_URL=postgresql+psycopg://switchboard:switchboard@localhost:5433/switchboard_test